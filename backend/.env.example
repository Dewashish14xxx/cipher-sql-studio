PORT=5000

# MongoDB connection string (Atlas or local)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/ciphersql?retryWrites=true&w=majority

# PostgreSQL connection (your local or hosted PG)
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_pg_password
PG_DATABASE=ciphersql_sandbox

# Google Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# JWT secret for auth (optional feature)
JWT_SECRET=change_this_to_a_long_random_secret

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
